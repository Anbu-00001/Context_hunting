# ===========================
# QUORUM — .gitignore
# ===========================
# Optimized for Node.js / TypeScript / Devvit / N8N / Gemini

# ----- Node.js -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ----- Build Artifacts -----
dist/
build/
out/
*.js.map
*.d.ts
!src/**/*.d.ts

# ----- TypeScript -----
*.tsbuildinfo

# ----- Devvit -----
.devvit/
devvit-build/
.devvit-cache/
playtest-state/

# ----- Environment & Secrets -----
.env
.env.*
!.env.example

# ----- N8N Credentials -----
n8n-creds/
*.n8n-credentials.json
n8n_config.json

# ----- Google Gemini / API Keys -----
gemini-credentials.json
service-account*.json
*.pem
*.key

# ----- IDE & Editor -----
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ----- macOS -----
.DS_Store
.AppleDouble
.LSOverride
._*

# ----- Linux -----
*~
.directory

# ----- Windows -----
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- Testing & Coverage -----
coverage/
.nyc_output/
*.lcov

# ----- Misc -----
*.log
*.tmp
*.bak
*.orig
.cache/
